# Mapbox Access Token
# Get your token from: https://account.mapbox.com/access-tokens/
VITE_MAPBOX_ACCESS_TOKEN=your_mapbox_access_token_here
VITE_VRP_API_BASE=http://localhost:3001/api

# Intlayer AI translation provider
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# If you already expose DeepSeek through Anthropic-compatible env vars,
# intlayer.config.js also falls back to these token/model names.
# Keep DEEPSEEK_BASE_URL for the deepseek provider; do not use the /anthropic endpoint here.
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_MODEL=deepseek-v4-pro
